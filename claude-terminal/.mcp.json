{
  "_comment": "Reference only. At runtime start-session.sh regenerates .mcp.json in each user HOME with unified-auth headers (Authorization/X-Odoo-Url/X-Odoo-Db/X-Odoo-Login) for the odoo-rpc server.",
  "mcpServers": {
    "odoo-rpc": {
      "type": "http",
      "url": "http://odoo-rpc-mcp:8084/mcp",
      "headers": {
        "Authorization": "Bearer <ODOO_API_KEY>",
        "X-Odoo-Url":    "<ODOO_URL>",
        "X-Odoo-Db":     "<ODOO_DB>",
        "X-Odoo-Login":  "<ODOO_LOGIN>"
      }
    },
    "portainer": {
      "type": "sse",
      "url": "http://portainer-mcp:8085/sse"
    },
    "github": {
      "type": "http",
      "url": "http://github-mcp:8086/mcp"
    },
    "teams": {
      "type": "sse",
      "url": "http://teams-mcp:8087/sse"
    }
  }
}
