# ═══════════════════════════════════════════════════════════
# Claude Code + terminal-control-mcp
# ═══════════════════════════════════════════════════════════

# Anthropic API Key (required for Claude Code CLI)
ANTHROPIC_API_KEY=

# Web UI port (terminal-control-mcp xterm.js)
TERMINAL_PORT=8080

# Git identity
GIT_USER_NAME=Rosen Vladimirov
GIT_USER_EMAIL=rosen@blconsulting.bg

# Workspace path on host
WORKSPACE_PATH=./_workspace

# MCP Servers available inside Claude Code sessions (JSON)
# Uses host.docker.internal to reach host-side MCP containers
# MCP_SERVERS_JSON={"mcpServers":{"telegram":{"type":"sse","url":"http://host.docker.internal:8081/sse"},"viber":{"type":"sse","url":"http://host.docker.internal:8082/sse"},"odoo":{"type":"sse","url":"http://host.docker.internal:8084/sse"}}}

# ─── Odoo RPC MCP ─────────────────────────────────────────
# Default connection (can also add more at runtime via odoo_connect tool)
ODOO_URL=http://localhost:8069
ODOO_DB=mydb
ODOO_USERNAME=admin

# Auth: use EITHER password OR api_key
ODOO_PASSWORD=admin
ODOO_API_KEY=

# Protocol: xmlrpc (Odoo 8+) or jsonrpc (Odoo 14+)
ODOO_PROTOCOL=xmlrpc

# MCP port
ODOO_MCP_PORT=8084
